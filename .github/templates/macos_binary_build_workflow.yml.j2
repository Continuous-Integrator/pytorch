{% import 'common.yml.j2' as common %}
{% import 'upload.yml.j2' as upload %}

{%- block name -%}
# Template is at:    .github/templates/macos_binary_build_workflow.yml.j2
# Generation script: .github/scripts/generate_ci_workflows.py
name: !{{ build_environment }}
{%- endblock %}

{#- Derive the setup-python micro-version from a DESIRED_PYTHON like "3.13" or "3.13t" -#}
{%- macro setup_python_version(py_ver) -%}
!{{ py_ver.strip('t') + ('.4' if '3.14' not in py_ver else '.0') }}
{%- endmacro %}

on:
# TODO: Migrate to new ciflow trigger, reference https://github.com/pytorch/pytorch/pull/70321
  push:
    # NOTE: Meta Employees can trigger new nightlies using: https://fburl.com/trigger_pytorch_nightly_build
    branches:
      - nightly
    tags:
      # NOTE: Binary build pipelines should only get triggered on release candidate builds
      # Release candidate tags look like: v1.11.0-rc1
      - v[0-9]+.[0-9]+.[0-9]+-rc[0-9]+
{%- for label in ciflow_config.labels | sort %}
    {%- if loop.first and branches != "nightly" %}
    tags:
    {%- endif %}
      - '!{{ label }}/*'
{%- endfor %}
  workflow_dispatch:

env:
  ALPINE_IMAGE: "308535385114.dkr.ecr.us-east-1.amazonaws.com/tool/alpine"
  AWS_DEFAULT_REGION: us-east-1
  BUILD_ENVIRONMENT: !{{ build_environment }}
  GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
  PR_NUMBER: ${{ github.event.pull_request.number }}
  SKIP_ALL_TESTS: 0
!{{ common.concurrency(build_environment) }}

jobs:
{%- if build_configs %}
  {%- set first = build_configs[0] %}
  # Builds every Python version sequentially on a single runner. libtorch_cpu
  # is Python-ABI-free and shared across iterations via `build/` — only
  # libtorch_python + _C are recompiled per interpreter (~5 min each after the
  # first ~80 min full build), thanks to the Python-cache invalidation in
  # tools/setup_helpers/cmake.py.
  wheel-build:
    if: ${{ github.repository_owner == 'pytorch' }}
    runs-on: !{{ macos_runner }}
    timeout-minutes: !{{ common.timeout_minutes }}
    env:
      PYTORCH_ROOT: ${{ github.workspace }}
      PACKAGE_TYPE: !{{ first["package_type"] }}
      # TODO: This is a legacy variable that we eventually want to get rid of in
      #       favor of GPU_ARCH_VERSION
      DESIRED_CUDA: !{{ first["desired_cuda"] }}
      GPU_ARCH_TYPE: !{{ first["gpu_arch_type"] }}
      SKIP_ALL_TESTS: 1
      {%- if first.pytorch_extra_install_requirements is defined and first.pytorch_extra_install_requirements|d('')|length > 0 %}
      PYTORCH_EXTRA_INSTALL_REQUIREMENTS: !{{ first.pytorch_extra_install_requirements }}
      {%- endif %}
    steps:
      # NOTE: These environment variables are put here so that they can be applied on every job equally
      #       They are also here because setting them at a workflow level doesn't give us access to the
      #       runner.temp variable, which we need.
      - name: Populate runner env
        shell: bash
        run: |
          # shellcheck disable=SC2129
          echo "BINARY_ENV_FILE=${RUNNER_TEMP}/env" >> "${GITHUB_ENV}"
      - name: Checkout PyTorch
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event_name == 'pull_request' && github.event.pull_request.head.sha || github.sha }}
          submodules: recursive
          show-progress: false
      - name: Clean PyTorch checkout
        run: |
          # Remove any artifacts from the previous checkouts
          git clean -fxd
      - name: Install libomp
        run: "${PYTORCH_ROOT}/.ci/wheel/install_libomp.sh"
      # Build phase: compile a wheel per CPython version without delocating.
      # libtorch_cpu is reused across iterations via `build/`; only libtorch_python
      # + _C recompile thanks to the Python-cache invalidation in cmake.py.
{%- for config in build_configs %}
      - name: Setup Python !{{ config["python_version"] }}
        uses: actions/setup-python@v6
        with:
          # .4 version is min minor for 3.10, and also no-gil version of 3.13 needs at least 3.13.3
          python-version: "!{{ setup_python_version(config["python_version"]) }}"
          freethreaded: !{{ "true" if config["python_version"].endswith('t') else "false" }}
      - name: Build wheel !{{ config["python_version"] }}
        env:
          DESIRED_PYTHON: "!{{ config["python_version"] }}"
          # Per-iteration output/work dirs so wheels and whl_tmp_dir stay isolated.
          PYTORCH_FINAL_PACKAGE_DIR: ${{ runner.temp }}/artifacts/!{{ config["build_name"] }}
          MAC_PACKAGE_WORK_DIR: ${{ runner.temp }}/work/!{{ config["build_name"] }}
        run: |
          set -eux -o pipefail
          mkdir -p "$PYTORCH_FINAL_PACKAGE_DIR" "$MAC_PACKAGE_WORK_DIR"
          # Rewrite BINARY_ENV_FILE with values derived from this iteration's DESIRED_PYTHON.
          "${PYTORCH_ROOT}/.ci/pytorch/binary_populate_env.sh"
          # shellcheck disable=SC1090
          source "$BINARY_ENV_FILE"

          USE_PYTORCH_METAL_EXPORT=1
          USE_COREML_DELEGATE=1
          TORCH_PACKAGE_NAME="${TORCH_PACKAGE_NAME//-/_}"
          export USE_PYTORCH_METAL_EXPORT USE_COREML_DELEGATE TORCH_PACKAGE_NAME
          "${PYTORCH_ROOT}/.ci/wheel/build_wheel.sh"
{%- endfor %}
      - name: Delocate all wheels
        run: "${PYTORCH_ROOT}/.ci/wheel/delocate_wheels.sh"
{%- if first["package_type"] == "wheel" %}
      # Smoke-test + upload phase: each iteration re-activates its Python
      # (cache hit from the build phase) and exercises the delocated wheel.
{%- for config in build_configs %}
      - name: Setup Python !{{ config["python_version"] }} (smoke)
        uses: actions/setup-python@v6
        with:
          python-version: "!{{ setup_python_version(config["python_version"]) }}"
          freethreaded: !{{ "true" if config["python_version"].endswith('t') else "false" }}
      - name: Smoke-test wheel !{{ config["python_version"] }}
        env:
          PYTORCH_FINAL_PACKAGE_DIR: ${{ runner.temp }}/artifacts/!{{ config["build_name"] }}
        run: |
          set -eux -o pipefail
          venv_dir="${RUNNER_TEMP}/test_venv_!{{ config["build_name"] }}"
          rm -rf "$venv_dir"
          python -mvenv "$venv_dir"
          # shellcheck disable=SC1091
          source "$venv_dir/bin/activate"
          pip install "$PYTORCH_FINAL_PACKAGE_DIR"/*.whl numpy -v
          python "${PYTORCH_ROOT}/.ci/pytorch/smoke_test/smoke_test.py" --package torchonly
          deactivate
      - name: Upload !{{ config["build_name"] }}
        uses: actions/upload-artifact@v4.4.0
        if: always()
        with:
          name: !{{ config["build_name"] }}
          retention-days: 14
          if-no-files-found: error
          path: ${{ runner.temp }}/artifacts/!{{ config["build_name"] }}
{%- endfor %}
{%- else %}
{%- for config in build_configs %}
      - name: Upload !{{ config["build_name"] }}
        uses: actions/upload-artifact@v4.4.0
        if: always()
        with:
          name: !{{ config["build_name"] }}
          retention-days: 14
          if-no-files-found: error
          path: ${{ runner.temp }}/artifacts/!{{ config["build_name"] }}
{%- endfor %}
{%- endif %}

  wheel-upload:
    if: ${{ github.repository_owner == 'pytorch' }}
    permissions:
      id-token: write
      contents: read
    needs: wheel-build
    strategy:
      fail-fast: false
      matrix:
        include:
        {%- for config in build_configs %}
          - desired_python: "!{{ config["python_version"] }}"
            build_name: !{{ config["build_name"] }}
        {%- endfor %}
    with:
      PYTORCH_ROOT: /pytorch
      PACKAGE_TYPE: !{{ first["package_type"] }}
      DESIRED_CUDA: !{{ first["desired_cuda"] }}
      GPU_ARCH_TYPE: !{{ first["gpu_arch_type"] }}
      DOCKER_IMAGE: !{{ first["container_image"] }}
      DOCKER_IMAGE_TAG_PREFIX: !{{ first["container_image_tag_prefix"] }}
      DESIRED_PYTHON: ${{ matrix.desired_python }}
      build_name: ${{ matrix.build_name }}
      use_s3: False
    secrets:
      github-token: ${{ secrets.GITHUB_TOKEN }}
      R2_ACCOUNT_ID: ${{ secrets.R2_ACCOUNT_ID }}
      R2_ACCESS_KEY_ID: ${{ secrets.R2_ACCESS_KEY_ID }}
      R2_SECRET_ACCESS_KEY: ${{ secrets.R2_SECRET_ACCESS_KEY }}
    uses: ./.github/workflows/_binary-upload.yml
{%- endif %}

{%- for lt_config in libtorch_extraction_configs %}
  !{{ lt_config["build_name"] }}-extract:
    if: ${{ github.repository_owner == 'pytorch' }}
    needs: wheel-build
    runs-on: !{{ macos_runner }}
    timeout-minutes: 60
    env:
      DESIRED_CUDA: !{{ lt_config["desired_cuda"] }}
      LIBTORCH_VARIANT: !{{ lt_config["libtorch_variant"] }}
    steps:
      - name: Checkout PyTorch
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event_name == 'pull_request' && github.event.pull_request.head.sha || github.sha }}
          sparse-checkout: .ci/libtorch/
          show-progress: false
      - name: Setup Python
        uses: actions/setup-python@v6
        with:
          python-version: "3.10.4"
          freethreaded: false
      - uses: actions/download-artifact@v4.1.7
        name: Download Wheel Artifact
        with:
          name: !{{ lt_config["source_wheel_build_name"] }}
          path: "${{ runner.temp }}/wheel_artifact/"
      - name: Extract libtorch from wheel
        run: |
          set -eux
          mkdir -p "${{ runner.temp }}/libtorch_output"
          python3 .ci/libtorch/extract_libtorch_from_wheel.py \
            --wheel-dir "${{ runner.temp }}/wheel_artifact" \
            --output-dir "${{ runner.temp }}/libtorch_output" \
            --platform macos \
            --desired-cuda "$DESIRED_CUDA" \
            --libtorch-variant "$LIBTORCH_VARIANT"
      - uses: actions/upload-artifact@v4.4.0
        if: always()
        with:
          name: !{{ lt_config["build_name"] }}
          retention-days: 14
          if-no-files-found: error
          path: "${{ runner.temp }}/libtorch_output/"
  !{{ upload.upload_extracted_libtorch(lt_config, use_s3=False) }}
{%- endfor %}
